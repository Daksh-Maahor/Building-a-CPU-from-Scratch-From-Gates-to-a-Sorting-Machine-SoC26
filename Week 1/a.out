#! /usr/bin/vvp
:ivl_version "12.0 (stable)";
:ivl_delay_selection "TYPICAL";
:vpi_time_precision - 9;
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/system.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_sys.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_textio.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/v2005_math.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/va_math.vpi";
S_0x635df89a74f0 .scope module, "mux2to1_tb" "mux2to1_tb" 2 7;
 .timescale -9 -9;
v0x635df89bb560_0 .var "a", 0 0;
v0x635df89bb620_0 .var "b", 0 0;
v0x635df89bb6f0_0 .var "sel", 0 0;
v0x635df89bb7f0_0 .net "y", 0 0, L_0x635df89bb8c0;  1 drivers
S_0x635df89a7680 .scope module, "uut" "mux2to1" 2 11, 2 1 0, S_0x635df89a74f0;
 .timescale 0 0;
    .port_info 0 /INPUT 1 "a";
    .port_info 1 /INPUT 1 "b";
    .port_info 2 /INPUT 1 "sel";
    .port_info 3 /OUTPUT 1 "y";
v0x635df89a78d0_0 .net "a", 0 0, v0x635df89bb560_0;  1 drivers
v0x635df89bb290_0 .net "b", 0 0, v0x635df89bb620_0;  1 drivers
v0x635df89bb350_0 .net "sel", 0 0, v0x635df89bb6f0_0;  1 drivers
v0x635df89bb3f0_0 .net "y", 0 0, L_0x635df89bb8c0;  alias, 1 drivers
L_0x635df89bb8c0 .functor MUXZ 1, v0x635df89bb560_0, v0x635df89bb620_0, v0x635df89bb6f0_0, C4<>;
    .scope S_0x635df89a74f0;
T_0 ;
    %vpi_call 2 14 "$dumpfile", "wave.vcd" {0 0 0};
    %vpi_call 2 15 "$dumpvars", 32'sb00000000000000000000000000000000, S_0x635df89a74f0 {0 0 0};
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x635df89bb560_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x635df89bb620_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x635df89bb6f0_0, 0, 1;
    %delay 10, 0;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x635df89bb560_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x635df89bb620_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x635df89bb6f0_0, 0, 1;
    %delay 10, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x635df89bb560_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x635df89bb620_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x635df89bb6f0_0, 0, 1;
    %delay 10, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x635df89bb560_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x635df89bb620_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x635df89bb6f0_0, 0, 1;
    %delay 10, 0;
    %vpi_call 2 22 "$display", "Done" {0 0 0};
    %vpi_call 2 23 "$finish" {0 0 0};
    %end;
    .thread T_0;
    .scope S_0x635df89a74f0;
T_1 ;
    %vpi_call 2 26 "$monitor", "t=%0t | sel=%b a=%b b=%b | y=%b", $time, v0x635df89bb6f0_0, v0x635df89bb560_0, v0x635df89bb620_0, v0x635df89bb7f0_0 {0 0 0};
    %end;
    .thread T_1;
